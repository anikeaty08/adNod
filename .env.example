# =============================================================================
# AdNode env (Arbitrum Sepolia 421614 by default)
# Copy to .env and fill secrets. Next.js browser code reads NEXT_PUBLIC_*; API uses VITE_*.
# =============================================================================

# --- Chain & RPC ---
VITE_CHAIN_ID=421614
NEXT_PUBLIC_CHAIN_ID=421614
# Used by API / Hardhat Arbitrum network. Browser RPC for Wagmi:
VITE_FHENIX_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=
NEXT_PUBLIC_RPC_URL=
# Optional: switch default contract JSON to Helium deployments
# NEXT_PUBLIC_ADNODE_NETWORK=fhenixHelium
# VITE_ADNODE_NETWORK=fhenixHelium
FHENIX_HELIUM_RPC_URL=https://api.helium.fhenix.zone

# --- Contract addresses (set both VITE_* server + NEXT_PUBLIC_* browser) ---
VITE_ADREGISTRY_ADDRESS=
VITE_ADANALYTICS_ADDRESS=
VITE_PAYOUT_WRAPPER_ADDRESS=
NEXT_PUBLIC_AD_REGISTRY_ADDRESS=
NEXT_PUBLIC_AD_ANALYTICS_ADDRESS=
NEXT_PUBLIC_PAYOUT_WRAPPER_ADDRESS=

# --- WalletConnect (RainbowKit: prefers NEXT_PUBLIC_) ---
VITE_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- API ---
VITE_API_URL=http://127.0.0.1:4000
# Browser fetches (Host/Developer sync); defaults to VITE_API_URL in lib/adnode-api if unset
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
PORT=4000
# Comma-separated extra CORS origins for the Express API (localhost is always allowed)
# ADNODE_CORS_ORIGINS=https://your-app.vercel.app

# --- Database & AI ---
MONGO_URI=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Pinata (creative uploads) ---
PINATA_JWT=
PINATA_API_KEY=
PINATA_API_SECRET=

# --- Deploy / settlement keys (never commit real keys) ---
PRIVATE_KEY=
SETTLEMENT_PRIVATE_KEY=
WRAPPED_NATIVE_TOKEN_ADDRESS=

# --- App security ---
ADNODE_EMBED_SECRET=
ADNODE_SETTLEMENT_REPLAY_INTERVAL_MS=60000
ADNODE_STRICT_MODE=true
